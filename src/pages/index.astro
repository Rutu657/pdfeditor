---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Edit, Merge, and Convert PDFs Online">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-white pt-24 pb-32">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-sm font-medium text-brand-600 mb-8">
        <span class="flex h-2 w-2 rounded-full bg-brand-600 mr-2"></span>
        Fast, secure, and free online PDF editor
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-slate-900 mb-6">
        Edit PDF Files Directly In Your Browser
      </h1>
      <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
        No software to install. No registration required. Simply upload your PDF and start editing text, adding images, signatures, and annotations instantly.
      </p>
      
      <!-- Upload Area -->
      <div id="upload-container" class="mx-auto max-w-2xl mt-12 bg-white rounded-2xl border-2 border-dashed border-brand-200 p-12 transition-all hover:border-brand-500 shadow-sm relative group cursor-pointer">
        <input type="file" id="pdf-file-input" accept=".pdf" class="hidden" />
        <div class="absolute inset-0 bg-brand-50/50 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl pointer-events-none"></div>
        <div class="relative z-10 flex flex-col items-center pointer-events-none">
          <div class="h-16 w-16 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          </div>
          <h3 class="text-2xl font-semibold mb-2 text-slate-800">Upload a PDF document</h3>
          <p class="text-slate-500 mb-8">Drag and drop a file here, or click to select</p>
          <div class="flex gap-4">
            <button id="select-pdf-btn" type="button" class="inline-flex h-11 items-center justify-center rounded-md bg-brand-600 px-8 font-medium text-white shadow transition-all hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 pointer-events-auto">
              Select PDF File
            </button>
          </div>
          <p class="text-xs text-slate-400 mt-4">Secure processing. Files are deleted automatically.</p>
        </div>
      </div>

<script>
  import { storePdf } from '../utils/db.js';

  const uploadContainer = document.getElementById('upload-container');
  const fileInput = document.getElementById('pdf-file-input') as HTMLInputElement;
  const selectBtn = document.getElementById('select-pdf-btn');

  if (uploadContainer && fileInput && selectBtn) {
    const triggerInput = (e: Event) => {
      e.stopPropagation();
      fileInput.click();
    };

    uploadContainer.addEventListener('click', triggerInput);
    selectBtn.addEventListener('click', triggerInput);

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (file && file.type === 'application/pdf') {
        try {
          await storePdf(file);
          window.location.href = '/editor';
        } catch (err) {
          console.error('Failed to store PDF:', err);
          alert('Failed to process PDF file. Please try again.');
        }
      } else if (file) {
        alert('Please select a valid PDF file.');
      }
    });

    // Drag and drop handlers
    uploadContainer.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadContainer.classList.add('border-brand-500', 'bg-brand-50/50');
    });

    uploadContainer.addEventListener('dragleave', () => {
      uploadContainer.classList.remove('border-brand-500', 'bg-brand-50/50');
    });

    uploadContainer.addEventListener('drop', async (e) => {
      e.preventDefault();
      uploadContainer.classList.remove('border-brand-500', 'bg-brand-50/50');
      
      const file = e.dataTransfer?.files?.[0];
      if (file && file.type === 'application/pdf') {
        try {
          await storePdf(file);
          window.location.href = '/editor';
        } catch (err) {
          console.error('Failed to store PDF:', err);
          alert('Failed to process PDF file. Please try again.');
        }
      } else if (file) {
        alert('Only PDF files are supported.');
      }
    });
  }
</script>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="border-y border-slate-100 bg-slate-50 py-16">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center divide-x divide-slate-200">
        <div class="px-4">
          <div class="font-semibold text-lg text-slate-900 mb-1">100% Secure</div>
          <p class="text-sm text-slate-500">End-to-end encryption</p>
        </div>
        <div class="px-4">
          <div class="font-semibold text-lg text-slate-900 mb-1">Lightning Fast</div>
          <p class="text-sm text-slate-500">Browser-based editing</p>
        </div>
        <div class="px-4">
          <div class="font-semibold text-lg text-slate-900 mb-1">No Installation</div>
          <p class="text-sm text-slate-500">Works on any device</p>
        </div>
        <div class="px-4">
          <div class="font-semibold text-lg text-slate-900 mb-1">Auto Delete</div>
          <p class="text-sm text-slate-500">Files removed after 2 hours</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Everything you need to edit PDFs</h2>
        <p class="text-lg text-slate-600">A complete suite of tools to modify, manage, and enhance your PDF documents without leaving your browser.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {[
          { title: 'Edit Text', desc: 'Modify existing text or add new text blocks anywhere on the page.', icon: 'M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z' },
          { title: 'Add Images', desc: 'Insert logos, photos, and graphics into your PDF documents instantly.', icon: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12' },
          { title: 'E-Signatures', desc: 'Draw, type, or upload your signature to sign documents legally and securely.', icon: 'M15.5 3.5 12 7l3.5 3.5 M4 21h16 M12 7v10' },
          { title: 'Annotations', desc: 'Highlight text, draw shapes, and add comments for easy collaboration.', icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z' },
          { title: 'Page Management', desc: 'Reorder, rotate, extract, or delete specific pages from your PDF file.', icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8' },
          { title: 'Easy Export', desc: 'Download your edited PDF or compress it to save storage space.', icon: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3' }
        ].map(feature => (
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-md transition-shadow">
            <div class="h-10 w-10 bg-brand-100 text-brand-600 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={feature.icon}/></svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">{feature.title}</h3>
            <p class="text-slate-600 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-24 bg-slate-900 text-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">How it works</h2>
        <p class="text-lg text-slate-400">Edit your PDFs in three simple steps. No credit card required.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-12 max-w-5xl mx-auto relative">
        <div class="hidden md:block absolute top-12 left-1/6 right-1/6 h-0.5 bg-slate-800"></div>
        
        <div class="relative z-10 text-center">
          <div class="w-24 h-24 bg-slate-800 border-4 border-slate-900 rounded-full flex items-center justify-center text-3xl font-bold text-brand-400 mx-auto mb-6">1</div>
          <h3 class="text-xl font-semibold mb-3">Upload PDF</h3>
          <p class="text-slate-400">Drag and drop your file into the browser. Your file is securely uploaded over an encrypted connection.</p>
        </div>
        
        <div class="relative z-10 text-center">
          <div class="w-24 h-24 bg-brand-600 border-4 border-slate-900 rounded-full flex items-center justify-center text-3xl font-bold text-white mx-auto mb-6 shadow-lg shadow-brand-500/20">2</div>
          <h3 class="text-xl font-semibold mb-3">Edit Document</h3>
          <p class="text-slate-400">Add text, images, shapes or signatures. Rearrange pages or highlight important information.</p>
        </div>
        
        <div class="relative z-10 text-center">
          <div class="w-24 h-24 bg-slate-800 border-4 border-slate-900 rounded-full flex items-center justify-center text-3xl font-bold text-brand-400 mx-auto mb-6">3</div>
          <h3 class="text-xl font-semibold mb-3">Download</h3>
          <p class="text-slate-400">Export your edited PDF instantly. Your original and edited files are deleted from our servers shortly after.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {[
          { q: 'Is it free to use the PDF editor?', a: 'Yes, our basic editing tools are completely free to use. You can edit text, add images, and sign documents without paying.' },
          { q: 'Are my files secure?', a: 'Absolutely. We use 256-bit SSL encryption for all file transfers. Your files are processed automatically and deleted from our servers within 2 hours of upload.' },
          { q: 'Do I need to install any software?', a: 'No. Our PDF editor works entirely in your web browser. There is nothing to download or install, making it completely safe and extremely fast.' },
          { q: 'Can I use this on my mobile phone?', a: 'Yes! Our website is fully responsive and works perfectly on smartphones and tablets, allowing you to edit or sign PDFs on the go.' },
        ].map(faq => (
          <div class="border border-slate-200 rounded-lg p-6 bg-slate-50">
            <h3 class="text-lg font-semibold mb-2">{faq.q}</h3>
            <p class="text-slate-600">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-brand-50">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">Ready to edit your PDF?</h2>
      <p class="text-lg text-slate-600 mb-8">Join thousands of users who trust our platform for their daily document editing needs.</p>
      <a href="/editor" class="inline-flex h-12 items-center justify-center rounded-md bg-brand-600 px-8 text-lg font-medium text-white shadow transition-colors hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
        Start Editing Now
      </a>
    </div>
  </section>
</Layout>