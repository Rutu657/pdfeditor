---
import Layout from '../layouts/Layout.astro';
---

<Layout title="PDF Editor - Edit PDF files directly in your browser">
  <!-- Load PDF.js, PDF-lib, and styles -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf_viewer.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" is:inline></script>
  <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>

  <style is:global>
    /* Styling to blend PDF.js text layer onto our canvas wrappers */
    .textLayer {
      opacity: 1.0 !important;
      mix-blend-mode: multiply;
      pointer-events: auto !important;
      z-index: 10;
    }
    .textLayer span {
      color: transparent !important;
      background: transparent !important;
      cursor: text !important;
      pointer-events: auto !important;
    }
    .textLayer ::selection {
      background: rgba(14, 165, 233, 0.3) !important;
    }
    /* Editable overlay styling - outline only, transparent background */
    .page-text-box {
      z-index: 20;
      background: transparent !important;
      border: 1px solid transparent !important;
      box-shadow: none !important;
      overflow: hidden !important;
      padding: 0 !important;
      margin: 0 !important;
      box-sizing: border-box !important;
    }
    .page-text-box.selected {
      border: 1px solid #3b82f6 !important; /* Thin outline only during edit */
      outline: none !important;
      background: transparent !important;
      box-shadow: none !important;
    }
    .text-content {
      background: transparent !important;
      outline: none !important;
      border: none !important;
      padding: 0 !important;
      margin: 0 !important;
      width: 100%;
      height: 100%;
      box-sizing: border-box !important;
      white-space: pre-wrap !important; /* Allow wrapping while preserving spaces */
      word-break: break-word !important;
      overflow: visible !important;
      caret-color: currentColor !important;
    }
    .page-signature-box {
      z-index: 20;
    }
    .page-highlight-box {
      z-index: 12;
    }
  </style>

  <div class="flex-1 flex flex-col h-[calc(100vh-64px)] overflow-hidden bg-slate-100">
    <!-- Substitution Warning Banner -->
      <div id="substitution-warning-banner" class="hidden bg-amber-50 border-b border-amber-200 px-4 py-2 flex items-center justify-between text-xs text-amber-800 shrink-0 z-20">
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-amber-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
          <span><strong>Font Substitution:</strong> Some custom fonts in this PDF could not be embedded directly and were substituted with standard PDF fonts on download.</span>
        </div>
        <button id="dismiss-substitution-warning" class="text-amber-500 hover:text-amber-700 font-bold px-2 py-0.5 rounded cursor-pointer select-none">Dismiss</button>
      </div>
      <div id="scanned-pdf-banner" class="hidden bg-blue-50 border-b border-blue-200 px-4 py-2 flex items-center justify-between text-xs text-blue-800 shrink-0 z-20">
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-blue-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="16" x2="12" y1="12"/><line x1="12" x2="12.01" y1="8" x2="12" y1="8"/></svg>
          <span><strong>Scanned PDF Detected:</strong> This PDF appears to be a scanned document (no selectable text). Text editing is limited; you can still add new text, images, and signatures.</span>
        </div>
        <button id="dismiss-scanned-warning" class="text-blue-500 hover:text-blue-700 font-bold px-2 py-0.5 rounded cursor-pointer select-none">Dismiss</button>
      </div>

    <!-- Editor Toolbar -->
    <div class="h-14 bg-white border-b border-slate-200 flex items-center justify-between px-4 shrink-0 z-20">
      <div class="flex items-center gap-2">
        <button id="btn-add-text" class="p-2 hover:bg-slate-100 rounded text-slate-600 flex items-center gap-1 transition-all" title="Add Text">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" x2="15" y1="20" y2="20"/><line x1="12" x2="12" y1="4" y2="20"/></svg>
          <span class="text-xs font-medium hidden sm:inline">Add Text</span>
        </button>
        <button id="btn-sign" class="p-2 hover:bg-slate-100 rounded text-slate-600 flex items-center gap-1 transition-all" title="Sign">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a2.4 2.4 0 1 0-3.39-3.39l-12 12-1 4 4-1 12-12Z"/><path d="M16 8l-3-3"/></svg>
          <span class="text-xs font-medium hidden sm:inline">Sign</span>
        </button>
        <button id="btn-highlight" class="p-2 hover:bg-slate-100 rounded text-slate-600 flex items-center gap-1 transition-all" title="Highlight">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l-6 6v3h9l3-3"/><path d="M22 12l-4.6 4.6a2 2 0 0 1-2.8 0l-5.2-5.2a2 2 0 0 1 0-2.8L14 4"/></svg>
          <span class="text-xs font-medium hidden sm:inline">Highlight</span>
        </button>
        
        <!-- Context-sensitive Text Formatting Toolbar -->
        <div id="text-formatting-toolbar" class="hidden flex items-center gap-1.5 border-l border-slate-200 pl-3 ml-2">
          <select id="tb-font-family" class="text-xs border-slate-200 rounded-md h-8 shadow-sm focus:border-brand-500 focus:ring-brand-500 bg-white">
            <option value="Helvetica">Helvetica</option>
            <option value="Times Roman">Times Roman</option>
            <option value="Courier">Courier</option>
          </select>
          <input type="number" id="tb-font-size" value="16" min="8" max="72" class="text-xs border-slate-200 rounded-md h-8 w-14 shadow-sm focus:border-brand-500 focus:ring-brand-500 bg-white">
          <input type="color" id="tb-font-color" value="#000000" class="h-8 w-8 rounded-md border border-slate-200 cursor-pointer bg-white" />
          
          <div class="h-8 w-px bg-slate-200 mx-1"></div>
          
          <button id="tb-bold" type="button" class="h-8 w-8 flex items-center justify-center rounded border border-slate-200 hover:bg-slate-50 font-bold text-xs transition-all bg-white" title="Bold">B</button>
          <button id="tb-italic" type="button" class="h-8 w-8 flex items-center justify-center rounded border border-slate-200 hover:bg-slate-50 italic text-xs transition-all bg-white" title="Italic">I</button>
          <button id="tb-underline" type="button" class="h-8 w-8 flex items-center justify-center rounded border border-slate-200 hover:bg-slate-50 underline text-xs transition-all bg-white" title="Underline">U</button>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <span id="editor-file-name" class="text-sm font-medium text-slate-600 max-w-[150px] sm:max-w-[250px] truncate">No file selected</span>
        <span id="save-status" class="px-2 py-0.5 rounded text-xs bg-slate-100 text-slate-500">Unsaved</span>
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1 bg-slate-100 rounded-md p-1">
          <button id="btn-zoom-out" class="p-1 hover:bg-white rounded text-slate-600 shadow-sm transition-all" title="Zoom Out">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" x2="16.65" y1="21" y2="16.65"/><line x1="8" x2="14" y1="11" y2="11"/></svg>
          </button>
          <span id="zoom-percentage" class="text-sm font-medium w-12 text-center select-none">100%</span>
          <button id="btn-zoom-in" class="p-1 hover:bg-white rounded text-slate-600 shadow-sm transition-all" title="Zoom In">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" x2="16.65" y1="21" y2="16.65"/><line x1="11" x2="11" y1="8" y2="14"/><line x1="8" x2="14" y1="11" y2="11"/></svg>
          </button>
        </div>
        <button id="btn-download" class="inline-flex h-9 items-center justify-center rounded-md bg-brand-600 px-4 py-2 text-sm font-medium text-white shadow transition-all hover:bg-brand-700 disabled:opacity-50 cursor-pointer">
          Download
        </button>
      </div>
    </div>

    <!-- Main Workspace -->
    <div class="flex-1 flex overflow-hidden relative">
      <!-- Upload Card (shown when no PDF is loaded) -->
      <div id="editor-upload-card" class="absolute inset-0 bg-slate-50 flex flex-col items-center justify-center p-8 z-30 transition-all duration-300">
        <div id="editor-drag-zone" class="w-full max-w-2xl bg-white rounded-2xl border-2 border-dashed border-brand-200 p-16 transition-all hover:border-brand-500 shadow-sm text-center cursor-pointer">
          <input type="file" id="editor-file-input" accept=".pdf" class="hidden" />
          <div class="flex flex-col items-center pointer-events-none">
            <div class="h-20 w-20 bg-brand-100 text-brand-600 rounded-2xl flex items-center justify-center mb-6 shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
            </div>
            <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-2">Upload your PDF</h2>
            <p class="text-lg text-slate-500 mb-8">Drag and drop a PDF file here, or click to browse</p>
            <button id="editor-select-btn" type="button" class="inline-flex h-12 items-center justify-center rounded-md bg-brand-600 px-8 font-medium text-white shadow transition-all hover:bg-brand-700 pointer-events-auto">
              Select PDF File
            </button>
          </div>
        </div>
      </div>

      <!-- Left Sidebar (Thumbnails) -->
      <div class="w-64 bg-white border-r border-slate-200 flex flex-col hidden md:flex shrink-0">
        <div class="p-4 border-b border-slate-200 font-medium text-sm text-slate-900">
          Pages
        </div>
        <div id="thumbnail-container" class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50">
          <!-- Dynamically populated page thumbnails -->
        </div>
      </div>

      <!-- Canvas Area -->
      <div class="flex-1 overflow-auto flex flex-col items-center justify-start p-8 bg-slate-100" id="editor-viewport">
        <div id="pages-container" class="space-y-6 flex flex-col items-center">
          <!-- Dynamically populated PDF canvases and text layers -->
        </div>
      </div>

      <!-- Right Sidebar (Properties) -->
      <div class="w-72 bg-white border-l border-slate-200 flex flex-col hidden lg:flex shrink-0">
        <div class="p-4 border-b border-slate-200 font-medium text-sm text-slate-900">
          Properties
        </div>
        <div class="p-4 space-y-6 overflow-y-auto">
          <div>
            <label class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-3">Typography</label>
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-slate-700 mb-1">Font Family</label>
                <select id="prop-font-family" class="w-full text-sm border-slate-200 rounded-md shadow-sm focus:border-brand-500 focus:ring-brand-500">
                  <option value="Helvetica">Helvetica</option>
                  <option value="Times Roman">Times Roman</option>
                  <option value="Courier">Courier</option>
                </select>
              </div>
              <div class="flex gap-2">
                <div class="flex-1">
                  <label class="block text-sm text-slate-700 mb-1">Size</label>
                  <input type="number" id="prop-font-size" value="16" min="8" max="72" class="w-full text-sm border-slate-200 rounded-md shadow-sm focus:border-brand-500 focus:ring-brand-500">
                </div>
                <div class="flex-1">
                  <label class="block text-sm text-slate-700 mb-1">Color</label>
                  <input type="color" id="prop-font-color" value="#000000" class="h-9 w-full rounded-md border border-slate-200 cursor-pointer bg-white" />
                </div>
              </div>
            </div>
          </div>
          <hr class="border-slate-100" />
          <div>
            <label class="block text-xs font-medium text-slate-500 uppercase tracking-wider mb-3">Styles</label>
            <div class="flex border border-slate-200 rounded-md overflow-hidden bg-slate-50">
              <button id="prop-bold" type="button" class="flex-1 p-2 flex justify-center text-slate-600 hover:bg-slate-100 font-bold transition-all">B</button>
              <button id="prop-italic" type="button" class="flex-1 p-2 flex justify-center text-slate-600 hover:bg-slate-100 italic transition-all">I</button>
              <button id="prop-underline" type="button" class="flex-1 p-2 flex justify-center text-slate-600 hover:bg-slate-100 underline transition-all">U</button>
            </div>
          </div>
          <hr class="border-slate-100" />
          <div class="text-xs text-slate-400">
            <p class="mb-2"><strong>Tips:</strong></p>
            <ul class="list-disc pl-4 space-y-1">
              <li><strong>Double-click any text</strong> inside the PDF to edit it inline.</li>
              <li>Click <strong>Add Text</strong> and click anywhere on the page to insert a new text block.</li>
              <li>Click <strong>Sign</strong> to place a custom drawn signature on pages.</li>
              <li>Click <strong>Highlight</strong> and drag over content to draw overlays.</li>
              <li>Clicking outside any text element automatically saves modifications.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Signature Modal -->
  <div id="signature-modal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md mx-4 transition-all">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold text-slate-900">Draw Your Signature</h3>
        <button id="close-signature-modal" class="text-slate-400 hover:text-slate-600 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
        </button>
      </div>
      <div class="border border-slate-200 rounded-lg overflow-hidden bg-slate-50 mb-4">
        <canvas id="signature-pad" class="w-full h-48 bg-white cursor-crosshair"></canvas>
      </div>
      <div class="flex justify-end gap-3">
        <button id="clear-signature" type="button" class="px-4 py-2 border border-slate-200 rounded-md text-slate-700 hover:bg-slate-50 text-sm font-medium cursor-pointer">Clear</button>
        <button id="save-signature" type="button" class="px-4 py-2 bg-brand-600 rounded-md text-white hover:bg-brand-700 text-sm font-medium cursor-pointer">Add Signature</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { getStoredPdf, storePdf, clearStoredPdf } from '../utils/db.js';

  // State interfaces
  interface TextEdit {
    id: string;
    pageNum: number;
    text: string;
    originalText?: string;
    
    // Percentage positions in UI
    xPct: number;
    yPct: number;
    wPct: number;
    hPct: number;
    
    // Formatting styles
    fontFamily: string; 
    originalPdfFontFamily?: string; 
    fontSize: number; 
    color: string;
    bold: boolean;
    italic: boolean;
    underline: boolean;
    letterSpacing: string;
    lineHeight: string;
    textAlign: string;
    transform?: string;
    transformOrigin?: string;

    // Background color sampled from canvas for cover-up masking
    backgroundColor: string;

    // PDF original coordinates for masking and alignment
    originalPdfX?: number;
    originalPdfY?: number;
    originalPdfW?: number;
    originalPdfH?: number;

    // PDF font weight for matching
    originalPdfFontWeight?: string;

    // Font metrics for precise baseline positioning
    originalFontAscent?: number;
    originalFontDescent?: number;
  }

  // Global states
  let pdfBytes: ArrayBuffer | null = null;
  let pdfDoc: any = null;
  let zoomFactor = 1.0;
  let activeTool: 'text' | 'signature' | 'highlight' | null = null;
  let pagesRendered: Array<{
    page: any;
    canvas: HTMLCanvasElement;
    thumbCanvas: HTMLCanvasElement;
    overlay: HTMLDivElement;
    pageWrapper: HTMLDivElement;
  }> = [];

  let pageTextStyles: Record<number, any> = {};
  let textEdits: Array<TextEdit> = [];
  let selectedBoxId: string | null = null;
  let cleanPageCanvases: Array<HTMLCanvasElement | null> = [];
  
  let savedSignatureDataUrl: string | null = null;
  let signatureClickPosition: { xPct: number; yPct: number; pageNum: number } | null = null;

  // DOM Elements
  const uploadCard = document.getElementById('editor-upload-card');
  const dragZone = document.getElementById('editor-drag-zone');
  const fileInput = document.getElementById('editor-file-input') as HTMLInputElement;
  const selectBtn = document.getElementById('editor-select-btn');
  const downloadBtn = document.getElementById('btn-download') as HTMLButtonElement;

  const btnAddText = document.getElementById('btn-add-text');
  const btnSign = document.getElementById('btn-sign');
  const btnHighlight = document.getElementById('btn-highlight');

  const btnZoomIn = document.getElementById('btn-zoom-in');
  const btnZoomOut = document.getElementById('btn-zoom-out');
  const zoomPercentage = document.getElementById('zoom-percentage');

  const signatureModal = document.getElementById('signature-modal');
  const signaturePad = document.getElementById('signature-pad') as HTMLCanvasElement;
  const closeSignatureModal = document.getElementById('close-signature-modal');
  const clearSignatureBtn = document.getElementById('clear-signature');
  const saveSignatureBtn = document.getElementById('save-signature');

  // Properties panel styling elements
  const propFontFamily = document.getElementById('prop-font-family') as HTMLSelectElement;
  const propFontSize = document.getElementById('prop-font-size') as HTMLInputElement;
  const propFontColor = document.getElementById('prop-font-color') as HTMLInputElement;
  const propBold = document.getElementById('prop-bold') as HTMLButtonElement;
  const propItalic = document.getElementById('prop-italic') as HTMLButtonElement;
  const propUnderline = document.getElementById('prop-underline') as HTMLButtonElement;

  // Context formatting toolbar elements
  const textFormattingToolbar = document.getElementById('text-formatting-toolbar');
  const tbFontFamily = document.getElementById('tb-font-family') as HTMLSelectElement;
  const tbFontSize = document.getElementById('tb-font-size') as HTMLInputElement;
  const tbFontColor = document.getElementById('tb-font-color') as HTMLInputElement;
  const tbBold = document.getElementById('tb-bold') as HTMLButtonElement;
  const tbItalic = document.getElementById('tb-italic') as HTMLButtonElement;
  const tbUnderline = document.getElementById('tb-underline') as HTMLButtonElement;

  const saveStatusSpan = document.getElementById('save-status');

  // Color conversion helpers
  function cssColorToHex(color: string): string {
    if (color.startsWith('rgb')) {
      const match = color.match(/\d+/g);
      if (match && match.length >= 3) {
        const r = parseInt(match[0]);
        const g = parseInt(match[1]);
        const b = parseInt(match[2]);
        return "#" + ((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1);
      }
    } else if (color.startsWith('#')) {
      return color;
    }
    return '#000000';
  }

  function cssColorToRgb(color: string): { r: number; g: number; b: number } {
    let r = 0, g = 0, b = 0;
    if (color.startsWith('rgb')) {
      const match = color.match(/\d+/g);
      if (match && match.length >= 3) {
        r = parseInt(match[0]) / 255;
        g = parseInt(match[1]) / 255;
        b = parseInt(match[2]) / 255;
      }
    } else if (color.startsWith('#')) {
      r = parseInt(color.slice(1, 3), 16) / 255;
      g = parseInt(color.slice(3, 5), 16) / 255;
      b = parseInt(color.slice(5, 7), 16) / 255;
    }
    return { r, g, b };
  }

  function markUnsaved() {
    if (saveStatusSpan) {
      saveStatusSpan.textContent = 'Unsaved';
      saveStatusSpan.className = 'px-2 py-0.5 rounded text-xs bg-amber-100 text-amber-600';
    }
  }

  function markSaved() {
    if (saveStatusSpan) {
      saveStatusSpan.textContent = 'Saved';
      saveStatusSpan.className = 'px-2 py-0.5 rounded text-xs bg-emerald-100 text-emerald-600';
    }
  }

  // Setup PDF.js worker
  // @ts-ignore
  const pdfjs = window.pdfjsLib;
  pdfjs.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

  // Signature Pad variables
  const sigCtx = signaturePad?.getContext('2d') || null;
  let isDrawingSig = false;

  // Initialization
  window.addEventListener('DOMContentLoaded', async () => {
    setupEventListeners();
    setupSignaturePad();
    
    const stored = await getStoredPdf();
    if (stored && stored.file) {
      const file = stored.file;
      const arrayBuffer = await file.arrayBuffer();
      uploadCard?.classList.add('hidden');
      await loadPDF(arrayBuffer, file.name);
    }
  });

  // Warn user about unsaved changes before leaving
  window.addEventListener('beforeunload', (e) => {
    const status = saveStatusSpan?.textContent;
    if (status === 'Unsaved') {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  function setupEventListeners() {
    // Zoom events — support 25% to 800%
    const ZOOM_MIN = 0.25;
    const ZOOM_MAX = 8.0;
    btnZoomIn?.addEventListener('click', async () => {
      let next = zoomFactor < 0.5 ? zoomFactor + 0.1
               : zoomFactor < 1.0 ? zoomFactor + 0.25
               : zoomFactor < 3.0 ? zoomFactor + 0.5
               : zoomFactor + 1.0;
      if (next <= ZOOM_MAX) {
        zoomFactor = Math.round(next * 100) / 100;
        if (zoomPercentage) zoomPercentage.textContent = `${Math.round(zoomFactor * 100)}%`;
        deselectActiveTextBox();
        await reRenderAllPages();
      }
    });

    btnZoomOut?.addEventListener('click', async () => {
      let next = zoomFactor <= 0.5 ? zoomFactor - 0.1
               : zoomFactor <= 1.0 ? zoomFactor - 0.25
               : zoomFactor <= 3.0 ? zoomFactor - 0.5
               : zoomFactor - 1.0;
      if (next >= ZOOM_MIN) {
        zoomFactor = Math.round(next * 100) / 100;
        if (zoomPercentage) zoomPercentage.textContent = `${Math.round(zoomFactor * 100)}%`;
        deselectActiveTextBox();
        await reRenderAllPages();
      }
    });

    // Uploader triggers
    const triggerFilePicker = (e: Event) => {
      e.stopPropagation();
      fileInput.click();
    };
    dragZone?.addEventListener('click', triggerFilePicker);
    selectBtn?.addEventListener('click', triggerFilePicker);

    fileInput?.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (file && file.type === 'application/pdf') {
        const arrayBuffer = await file.arrayBuffer();
        await storePdf(file);
        uploadCard?.classList.add('hidden');
        await loadPDF(arrayBuffer, file.name);
      } else if (file) {
        alert('Please choose a valid PDF file.');
      }
    });

    // Drag-and-drop on workspace
    dragZone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      dragZone.classList.add('border-brand-500', 'bg-brand-50/50');
    });

    dragZone?.addEventListener('dragleave', () => {
      dragZone.classList.remove('border-brand-500', 'bg-brand-50/50');
    });

    dragZone?.addEventListener('drop', async (e) => {
      e.preventDefault();
      dragZone.classList.remove('border-brand-500', 'bg-brand-50/50');

      const file = e.dataTransfer?.files?.[0];
      if (file && file.type === 'application/pdf') {
        const arrayBuffer = await file.arrayBuffer();
        await storePdf(file);
        uploadCard?.classList.add('hidden');
        await loadPDF(arrayBuffer, file.name);
      } else if (file) {
        alert('Only PDF files are supported.');
      }
    });

    // Tool Toggles
    btnAddText?.addEventListener('click', () => {
      toggleTool('text');
    });

    btnSign?.addEventListener('click', () => {
      toggleTool('signature');
    });

    btnHighlight?.addEventListener('click', () => {
      toggleTool('highlight');
    });

    // Properties / Toolbar edits sync
    const applyFontFamily = (val: string) => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) {
          edit.fontFamily = val;
          edit.originalPdfFontFamily = val;
        }
        const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
        if (div) div.style.fontFamily = val;
        
        propFontFamily.value = val;
        tbFontFamily.value = val;
        markUnsaved();
      }
    };

    const applyFontSize = (val: number) => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) edit.fontSize = val;
        const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
        if (div) div.style.fontSize = `${val * zoomFactor}px`;
        
        propFontSize.value = val.toString();
        tbFontSize.value = val.toString();
        markUnsaved();
      }
    };

    const applyFontColor = (val: string) => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) edit.color = val;
        const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
        if (div) div.style.color = val;
        
        propFontColor.value = val;
        tbFontColor.value = val;
        markUnsaved();
      }
    };

    const toggleBold = () => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) {
          edit.bold = !edit.bold;
          const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
          if (div) div.style.fontWeight = edit.bold ? 'bold' : 'normal';
          
          updateFormattingButtonsState(edit);
          markUnsaved();
        }
      }
    };

    const toggleItalic = () => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) {
          edit.italic = !edit.italic;
          const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
          if (div) div.style.fontStyle = edit.italic ? 'italic' : 'normal';
          
          updateFormattingButtonsState(edit);
          markUnsaved();
        }
      }
    };

    const toggleUnderline = () => {
      if (selectedBoxId) {
        const edit = textEdits.find(e => e.id === selectedBoxId);
        if (edit) {
          edit.underline = !edit.underline;
          const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
          if (div) div.style.textDecoration = edit.underline ? 'underline' : 'none';
          
          updateFormattingButtonsState(edit);
          markUnsaved();
        }
      }
    };

    propFontFamily.addEventListener('change', () => applyFontFamily(propFontFamily.value));
    tbFontFamily.addEventListener('change', () => applyFontFamily(tbFontFamily.value));

    propFontSize.addEventListener('input', () => applyFontSize(parseFloat(propFontSize.value) || 16));
    tbFontSize.addEventListener('input', () => applyFontSize(parseFloat(tbFontSize.value) || 16));

    propFontColor.addEventListener('input', () => applyFontColor(propFontColor.value));
    tbFontColor.addEventListener('input', () => applyFontColor(tbFontColor.value));

    propBold.addEventListener('click', toggleBold);
    tbBold.addEventListener('click', toggleBold);

    propItalic.addEventListener('click', toggleItalic);
    tbItalic.addEventListener('click', toggleItalic);

    propUnderline.addEventListener('click', toggleUnderline);
    tbUnderline.addEventListener('click', toggleUnderline);

    // Double-click event delegation
    document.getElementById('pages-container')?.addEventListener('dblclick', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'SPAN' && target.closest('.textLayer')) {
        e.stopPropagation();
        e.preventDefault();
        convertToEditableTextBox(target as HTMLSpanElement);
      }
    });

    // Deselect click listener
    document.addEventListener('mousedown', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.page-text-box') && !target.closest('#text-formatting-toolbar') && !target.closest('.lg\\:flex')) {
        deselectActiveTextBox();
      }
    });

    downloadBtn?.addEventListener('click', async () => {
      await downloadEditedPdf();
    });

    document.getElementById('dismiss-substitution-warning')?.addEventListener('click', () => {
      document.getElementById('substitution-warning-banner')?.classList.add('hidden');
    });

    document.getElementById('dismiss-scanned-warning')?.addEventListener('click', () => {
      document.getElementById('scanned-pdf-banner')?.classList.add('hidden');
    });
  }

  function updateFormattingButtonsState(edit: TextEdit) {
    const boldActive = edit.bold;
    const italicActive = edit.italic;
    const underlineActive = edit.underline;

    const btns = [
      { el: propBold, act: boldActive },
      { el: tbBold, act: boldActive },
      { el: propItalic, act: italicActive },
      { el: tbItalic, act: italicActive },
      { el: propUnderline, act: underlineActive },
      { el: tbUnderline, act: underlineActive }
    ];

    btns.forEach(b => {
      if (b.el) {
        if (b.act) {
          b.el.classList.add('bg-brand-100', 'text-brand-700', 'border-brand-300');
          b.el.classList.remove('text-slate-600', 'hover:bg-slate-100', 'border-slate-200');
        } else {
          b.el.classList.remove('bg-brand-100', 'text-brand-700', 'border-brand-300');
          b.el.classList.add('text-slate-600', 'hover:bg-slate-100', 'border-slate-200');
        }
      }
    });
  }

  function toggleTool(tool: 'text' | 'signature' | 'highlight') {
    if (activeTool === tool) {
      activeTool = null;
    } else {
      activeTool = tool;
    }
    
    const tools = [
      { id: 'btn-add-text', name: 'text' },
      { id: 'btn-sign', name: 'signature' },
      { id: 'btn-highlight', name: 'highlight' }
    ];

    tools.forEach(t => {
      const btn = document.getElementById(t.id);
      if (btn) {
        if (activeTool === t.name) {
          btn.classList.add('bg-brand-100', 'text-brand-700');
          btn.classList.remove('text-slate-600', 'hover:bg-slate-100');
        } else {
          btn.classList.remove('bg-brand-100', 'text-brand-700');
          btn.classList.add('text-slate-600', 'hover:bg-slate-100');
        }
      }
    });

    const overlays = document.querySelectorAll('.page-overlay');
    overlays.forEach(overlay => {
      const ov = overlay as HTMLElement;
      if (activeTool === 'text') {
        ov.style.cursor = 'text';
      } else if (activeTool === 'signature') {
        ov.style.cursor = 'pointer';
      } else if (activeTool === 'highlight') {
        ov.style.cursor = 'crosshair';
      } else {
        ov.style.cursor = 'default';
      }
    });
  }

  async function loadPDF(arrayBuffer: ArrayBuffer, fileName: string) {
    pdfBytes = arrayBuffer;
    textEdits = [];
    pageTextStyles = {};
    deselectActiveTextBox();
    document.getElementById('substitution-warning-banner')?.classList.add('hidden');
    
    const nameSpan = document.getElementById('editor-file-name');
    if (nameSpan) nameSpan.textContent = fileName;

    try {
      const loadingTask = pdfjs.getDocument({ data: arrayBuffer });
      pdfDoc = await loadingTask.promise;
      await renderWorkspace();
    } catch (err) {
      console.error('Failed to load PDF:', err);
      alert('Error loading PDF document. Make sure it is not password-protected.');
      uploadCard?.classList.remove('hidden');
    }
  }

  async function renderWorkspace() {
    const container = document.getElementById('pages-container');
    const thumbContainer = document.getElementById('thumbnail-container');
    if (!container || !thumbContainer) return;

    container.innerHTML = '';
    thumbContainer.innerHTML = '';
    pagesRendered = [];
    cleanPageCanvases = [];

    for (let pageNum = 1; pageNum <= pdfDoc.numPages; pageNum++) {
      const page = await pdfDoc.getPage(pageNum);
      
      const pageWrapper = document.createElement('div');
      pageWrapper.className = 'relative bg-white shadow-lg border border-slate-200 page-wrapper shrink-0';
      pageWrapper.dataset.pageNum = pageNum.toString();

      const canvas = document.createElement('canvas');
      canvas.className = 'block';
      pageWrapper.appendChild(canvas);

      const overlay = document.createElement('div');
      overlay.className = 'absolute inset-0 select-none page-overlay pointer-events-none';
      overlay.dataset.pageNum = pageNum.toString();
      pageWrapper.appendChild(overlay);

      container.appendChild(pageWrapper);

      // Thumbnail view setup
      const thumbWrapper = document.createElement('div');
      thumbWrapper.className = 'aspect-[1/1.4] bg-white border border-slate-200 rounded shadow-sm hover:border-brand-500 cursor-pointer relative p-1 overflow-hidden transition-all shrink-0';
      
      const pWrapperRef = pageWrapper;
      thumbWrapper.addEventListener('click', () => {
        pWrapperRef.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });

      const thumbCanvas = document.createElement('canvas');
      thumbCanvas.className = 'w-full h-full object-contain pointer-events-none';
      thumbWrapper.appendChild(thumbCanvas);

      const thumbNum = document.createElement('div');
      thumbNum.className = 'absolute bottom-1 right-1 bg-slate-900/60 text-white text-[10px] px-1.5 py-0.5 rounded backdrop-blur pointer-events-none';
      thumbNum.textContent = pageNum.toString();
      thumbWrapper.appendChild(thumbNum);

      thumbContainer.appendChild(thumbWrapper);

      pagesRendered.push({
        page,
        canvas,
        thumbCanvas,
        overlay,
        pageWrapper
      });

      await renderPage(page, canvas, thumbCanvas, overlay, pageWrapper);
      if (!overlay.dataset.interactionsSetup) {
        setupOverlayInteractions(overlay, pageNum);
        overlay.dataset.interactionsSetup = 'true';
      }
    }
  }

  async function renderPage(
    page: any,
    canvas: HTMLCanvasElement,
    thumbCanvas: HTMLCanvasElement,
    overlay: HTMLDivElement,
    pageWrapper: HTMLDivElement
  ) {
    const originalViewport = page.getViewport({ scale: 1.0 });
    const scale = zoomFactor * (760 / originalViewport.width); 
    const viewport = page.getViewport({ scale });

    canvas.width = viewport.width;
    canvas.height = viewport.height;

    pageWrapper.style.width = `${viewport.width}px`;
    pageWrapper.style.height = `${viewport.height}px`;

    const context = canvas.getContext('2d');
    if (context) {
      const renderContext = {
        canvasContext: context,
        viewport: viewport
      };
      await page.render(renderContext).promise;

      // Save a CLEAN snapshot of the canvas BEFORE any masks are drawn.
      // This is used for perfect background reconstruction (no color sampling artifacts).
      const pageNum = parseInt(pageWrapper.dataset.pageNum || '1');
      const cleanCanvas = document.createElement('canvas');
      cleanCanvas.width = canvas.width;
      cleanCanvas.height = canvas.height;
      const cleanCtx = cleanCanvas.getContext('2d');
      if (cleanCtx) {
        cleanCtx.drawImage(canvas, 0, 0);
      }
      cleanPageCanvases[pageNum] = cleanCanvas;

      // Draw cover-up canvas masks — now uses cleanCanvas drawImage for perfect backgrounds
      drawPageCanvasMasks(canvas, pageNum);
    }

    // Render / Update text layer overlay
    let textLayerDiv = pageWrapper.querySelector('.textLayer') as HTMLDivElement;
    if (textLayerDiv) {
      textLayerDiv.innerHTML = '';
    } else {
      textLayerDiv = document.createElement('div');
      textLayerDiv.className = 'textLayer absolute inset-0';
      pageWrapper.appendChild(textLayerDiv);
    }

    const pageNum = parseInt(pageWrapper.dataset.pageNum || '1');

    try {
      const textContent = await page.getTextContent();
      pageTextStyles[pageNum] = textContent.styles;

      // Detect scanned/image-based PDF (no text items)
      if (textContent.items.length === 0) {
        const scanBanner = document.getElementById('scanned-pdf-banner');
        if (scanBanner) scanBanner.classList.remove('hidden');
      }

      await pdfjs.renderTextLayer({
        textContent: textContent,
        container: textLayerDiv,
        viewport: viewport,
        enhanceTextSelection: true
      }).promise;
      
      hideMatchedTextSpans(textLayerDiv, pageNum);
    } catch (err) {
      console.error('Failed to render text layer for page:', pageNum, err);
    }

    // Thumb canvas viewport render
    const thumbScale = 160 / originalViewport.width;
    const thumbViewport = page.getViewport({ scale: thumbScale });
    thumbCanvas.width = thumbViewport.width;
    thumbCanvas.height = thumbViewport.height;

    const thumbContext = thumbCanvas.getContext('2d');
    if (thumbContext) {
      const thumbRenderContext = {
        canvasContext: thumbContext,
        viewport: thumbViewport
      };
      await page.render(thumbRenderContext).promise;
    }

    // Restore text overlays
    restoreOverlaysForPage(overlay, pageNum);
  }

  async function reRenderAllPages() {
    for (const p of pagesRendered) {
      await renderPage(p.page, p.canvas, p.thumbCanvas, p.overlay, p.pageWrapper);
    }
  }

  async function triggerPageReRender(pageNum: number) {
    const p = pagesRendered[pageNum - 1];
    if (p) {
      await renderPage(p.page, p.canvas, p.thumbCanvas, p.overlay, p.pageWrapper);
    }
  }

  function sampleCanvasBackgroundColor(canvas: HTMLCanvasElement, pageNum: number, canvasX: number, canvasY: number, canvasW: number, canvasH: number) {
    const context = canvas.getContext('2d');
    if (!context) return '#FFFFFF';

    try {
      // Multi-ring sampling: sample 4 concentric rings around the text box.
      // Average all samples for a gradient-friendly blend.
      const distances = [1, 2, 3, 5, 8, 12];
      const points: Array<[number, number]> = [];

      for (const d of distances) {
        // Top edge
        for (let frac = 0.1; frac <= 0.9; frac += 0.2) {
          points.push([Math.floor(canvasX + canvasW * frac), Math.floor(canvasY - d)]);
        }
        // Bottom edge
        for (let frac = 0.1; frac <= 0.9; frac += 0.2) {
          points.push([Math.floor(canvasX + canvasW * frac), Math.floor(canvasY + canvasH + d)]);
        }
        // Left edge
        for (let frac = 0.1; frac <= 0.9; frac += 0.2) {
          points.push([Math.floor(canvasX - d), Math.floor(canvasY + canvasH * frac)]);
        }
        // Right edge
        for (let frac = 0.1; frac <= 0.9; frac += 0.2) {
          points.push([Math.floor(canvasX + canvasW + d), Math.floor(canvasY + canvasH * frac)]);
        }
      }

      let totalR = 0, totalG = 0, totalB = 0, count = 0;

      for (const [sx, sy] of points) {
        if (sx >= 0 && sx < canvas.width && sy >= 0 && sy < canvas.height) {
          const imgData = context.getImageData(sx, sy, 1, 1).data;
          const r = imgData[0], g = imgData[1], b = imgData[2], a = imgData[3];
          // Exclude very dark pixels (text bleed) and transparent pixels
          if (a > 0 && !(r < 40 && g < 40 && b < 40)) {
            totalR += r;
            totalG += g;
            totalB += b;
            count++;
          }
        }
      }

      if (count > 0) {
        const avgR = Math.round(totalR / count);
        const avgG = Math.round(totalG / count);
        const avgB = Math.round(totalB / count);
        return "#" + ((1 << 24) + (avgR << 16) + (avgG << 8) + avgB).toString(16).slice(1);
      }

      return '#FFFFFF';
    } catch (e) {
      return '#FFFFFF';
    }
  }

  function drawPageCanvasMasks(canvas: HTMLCanvasElement, pageNum: number) {
    const context = canvas.getContext('2d');
    if (!context) return;

    const cleanCanvas = cleanPageCanvases[pageNum];
    if (!cleanCanvas) return;

    const pageMaskEdits = textEdits.filter(e => e.pageNum === pageNum && e.originalText && e.originalPdfX !== undefined);
    
    pageMaskEdits.forEach(edit => {
      if (edit.originalPdfX !== undefined && edit.originalPdfY !== undefined && edit.originalPdfW !== undefined && edit.originalPdfH !== undefined) {
        // Expand mask by 1px in each direction for anti-aliased edge coverage.
        const canvasX = Math.floor(edit.originalPdfX) - 1;
        const canvasY = Math.floor(edit.originalPdfY) - 1;
        const canvasW = Math.ceil(edit.originalPdfW) + 2;
        const canvasH = Math.ceil(edit.originalPdfH) + 2;

        // Perfection: copy the exact background pixels from the clean snapshot.
        // This handles gradients, textures, scanned pages, and shadows with zero artifacts.
        context.drawImage(
          cleanCanvas,
          canvasX, canvasY, canvasW, canvasH,  // source rect from clean snapshot
          canvasX, canvasY, canvasW, canvasH   // dest rect on live canvas
        );
      }
    });
  }

  function hideMatchedTextSpans(textLayer: HTMLDivElement, pageNum: number) {
    const pageMaskEdits = textEdits.filter(e => e.pageNum === pageNum && e.originalText);
    if (pageMaskEdits.length === 0) return;

    const spans = textLayer.querySelectorAll('span');
    spans.forEach(span => {
      const text = span.textContent?.trim() || '';
      if (!text) return;
      
      const hasMatch = pageMaskEdits.some(edit => edit.originalText === text);
      if (hasMatch) {
        span.style.opacity = '0';
        span.style.pointerEvents = 'none';
      }
    });
  }

  function restoreOverlaysForPage(overlay: HTMLDivElement, pageNum: number) {
    overlay.innerHTML = '';
    
    const pageEdits = textEdits.filter(e => e.pageNum === pageNum);
    pageEdits.forEach(edit => {
      renderTextBoxElement(overlay, edit);
    });
  }

  function setupOverlayInteractions(overlay: HTMLDivElement, pageNum: number) {
    overlay.addEventListener('click', (e) => {
      if (e.target !== overlay) return;

      const rect = overlay.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const xPct = (x / rect.width) * 100;
      const yPct = (y / rect.height) * 100;

      if (activeTool === 'text') {
        const id = 'edit_' + Math.random().toString(36).substr(2, 9);
        const minWPct = (60 / rect.width) * 100;
        const minHPct = (24 / rect.height) * 100;
        
        // Sample background color from canvas at click position
        const pageWrapper = overlay.closest('.page-wrapper') as HTMLDivElement;
        const canvas = pageWrapper?.querySelector('canvas') as HTMLCanvasElement;
        let bgColor = '#FFFFFF';
        if (canvas) {
          const ctx = canvas.getContext('2d');
          if (ctx) {
            const px = ctx.getImageData(Math.floor(x), Math.floor(y), 1, 1).data;
            if (px[3] > 0) {
              bgColor = "#" + ((1 << 24) + (px[0] << 16) + (px[1] << 8) + px[2]).toString(16).slice(1);
            }
          }
        }
        
        const newEdit: TextEdit = {
          id,
          pageNum,
          text: 'New Text',
          xPct,
          yPct,
          wPct: Math.max(20, minWPct),
          hPct: Math.max(4, minHPct),
          fontFamily: 'Helvetica',
          fontSize: 16,
          color: '#000000',
          bold: false,
          italic: false,
          underline: false,
          letterSpacing: 'normal',
          lineHeight: 'normal',
          textAlign: 'left',
          backgroundColor: bgColor
        };
        textEdits.push(newEdit);
        renderTextBoxElement(overlay, newEdit);
        selectTextBox(id);
        
        toggleTool('text');
      } else if (activeTool === 'signature') {
        signatureClickPosition = { xPct, yPct, pageNum };
        if (savedSignatureDataUrl) {
          placeSignature(overlay, xPct, yPct, savedSignatureDataUrl);
          toggleTool('signature');
        } else {
          openSignatureDialog();
        }
      }
    });

    // Highlight functionality (drag to draw)
    let isDrawingHighlight = false;
    let startX = 0;
    let startY = 0;
    let highlightBox: HTMLDivElement | null = null;

    overlay.addEventListener('mousedown', (e) => {
      if (activeTool !== 'highlight' || e.target !== overlay) return;
      isDrawingHighlight = true;

      const rect = overlay.getBoundingClientRect();
      startX = e.clientX - rect.left;
      startY = e.clientY - rect.top;

      highlightBox = document.createElement('div');
      highlightBox.className = 'absolute bg-yellow-300/40 border border-yellow-400/50 pointer-events-auto page-highlight-box cursor-pointer group';
      highlightBox.style.left = `${(startX / rect.width) * 100}%`;
      highlightBox.style.top = `${(startY / rect.height) * 100}%`;
      overlay.appendChild(highlightBox);

      const delBtn = document.createElement('button');
      delBtn.className = 'absolute -top-2 -right-2 hidden group-hover:flex items-center justify-center h-4 w-4 bg-red-500 hover:bg-red-600 text-white rounded-full shadow-sm cursor-pointer z-10';
      delBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>';
      const currentBox = highlightBox;
      delBtn.addEventListener('click', (evt) => {
        evt.stopPropagation();
        currentBox.remove();
        markUnsaved();
      });
      highlightBox.appendChild(delBtn);
    });

    overlay.addEventListener('mousemove', (e) => {
      if (!isDrawingHighlight || !highlightBox) return;

      const rect = overlay.getBoundingClientRect();
      const currentX = e.clientX - rect.left;
      const currentY = e.clientY - rect.top;

      const width = Math.abs(currentX - startX);
      const height = Math.abs(currentY - startY);

      const left = Math.min(startX, currentX);
      const top = Math.min(startY, currentY);

      highlightBox.style.left = `${(left / rect.width) * 100}%`;
      highlightBox.style.top = `${(top / rect.height) * 100}%`;
      highlightBox.style.width = `${(width / rect.width) * 100}%`;
      highlightBox.style.height = `${(height / rect.height) * 100}%`;
    });

    overlay.addEventListener('mouseup', () => {
      if (isDrawingHighlight) {
        isDrawingHighlight = false;
        highlightBox = null;
        toggleTool('highlight');
        markUnsaved();
      }
    });
  }

  function convertToEditableTextBox(span: HTMLSpanElement) {
    const pageWrapper = span.closest('.page-wrapper') as HTMLDivElement;
    const overlay = pageWrapper.querySelector('.page-overlay') as HTMLDivElement;
    const pageNum = parseInt(pageWrapper.dataset.pageNum || '1');

    const spanRect = span.getBoundingClientRect();
    const overlayRect = overlay.getBoundingClientRect();

    const xPct = ((spanRect.left - overlayRect.left) / overlayRect.width) * 100;
    const yPct = ((spanRect.top - overlayRect.top) / overlayRect.height) * 100;
    let wPct = (spanRect.width / overlayRect.width) * 100;
    let hPct = (spanRect.height / overlayRect.height) * 100;
    
    // Ensure minimum dimensions for usability
    const minWPct = (60 / overlayRect.width) * 100;
    const minHPct = (24 / overlayRect.height) * 100;
    if (wPct < minWPct) wPct = minWPct;
    if (hPct < minHPct) hPct = minHPct;

    const originalText = span.textContent?.trim() || '';

    // Calculate coordinates for masking.
    // IMPORTANT: we store these in CANVAS PIXEL SPACE (not PDF space) so that
    // drawPageCanvasMasks() can use them DIRECTLY (no scale multiplication).
    // downloadEditedPdf() will convert them back to PDF space by dividing by canvasScale.
    const pageObj = pagesRendered[pageNum - 1];
    const originalViewport = pageObj.page.getViewport({ scale: 1.0 });
    const canvasScale = zoomFactor * (760 / originalViewport.width);

    // Get the canvas FIRST (needed for both width lookup and color sampling).
    const canvas = pageWrapper.querySelector('canvas') as HTMLCanvasElement;

    // xPct/yPct/wPct/hPct are fractions of overlayRect, and overlayRect width ===
    // canvas pixel width (both are sized from the same `viewport.width`), so
    // canvas pixel coords are simply: (pct/100) * canvas.width
    const canvasW_actual = canvas.width;
    const canvasH_actual = canvas.height;

    const originalCanvasX = (xPct / 100) * canvasW_actual;
    const originalCanvasY = (yPct / 100) * canvasH_actual;
    const originalCanvasW = (wPct / 100) * canvasW_actual;
    const originalCanvasH = (hPct / 100) * canvasH_actual;

    // Detect Styles — look up PDF font metadata from text content styles
    const computedStyle = window.getComputedStyle(span);
    const cleanFontFamily = computedStyle.fontFamily.replace(/['"]/g, '');
    // pageTextStyles[pageNum] is keyed by internal font obj names (e.g. "g_d0_f1"), not CSS family strings.
    // Iterate all styles to find the one matching our CSS fontFamily.
    const textStyles = pageTextStyles[pageNum] || {};
    let originalPdfFontFamily = cleanFontFamily;
    let originalPdfFontWeight = '';
    let originalFontAscent: number | undefined;
    let originalFontDescent: number | undefined;
    for (const key of Object.keys(textStyles)) {
      const s = textStyles[key];
      if (s.fontFamily && cleanFontFamily.toLowerCase().includes(s.fontFamily.toLowerCase())) {
        originalPdfFontFamily = s.fontFamily;
        originalPdfFontWeight = s.fontWeight?.toString() || '';
        originalFontAscent = s.ascent;
        originalFontDescent = s.descent;
        break;
      }
    }

    const fontSizePx = parseFloat(computedStyle.fontSize) || 16;
    const relativeFontSize = fontSizePx / zoomFactor;

    // 1. Sample Background Color using canvas-pixel coordinates directly
    const backgroundColor = sampleCanvasBackgroundColor(canvas, pageNum, originalCanvasX, originalCanvasY, originalCanvasW, originalCanvasH);

    const id = 'edit_' + Math.random().toString(36).substr(2, 9);
    const newEdit: TextEdit = {
      id,
      pageNum,
      text: originalText,
      originalText,
      xPct,
      yPct,
      wPct,
      hPct,
      fontFamily: computedStyle.fontFamily, 
      originalPdfFontFamily,
      originalPdfFontWeight,
      originalFontAscent,
      originalFontDescent,
      fontSize: relativeFontSize,
      color: computedStyle.color,
      bold: computedStyle.fontWeight === 'bold' || parseInt(computedStyle.fontWeight) >= 700,
      italic: computedStyle.fontStyle === 'italic',
      underline: computedStyle.textDecoration.includes('underline'),
      letterSpacing: computedStyle.letterSpacing,
      lineHeight: computedStyle.lineHeight,
      textAlign: computedStyle.textAlign || 'left',
      transform: span.style.transform || computedStyle.transform,
      transformOrigin: span.style.transformOrigin || computedStyle.transformOrigin,
      backgroundColor,
      // Store CANVAS pixel coords so masking is pixel-perfect.
      // We keep the field name `originalPdfX/Y/W/H` for backward compatibility
      // with the rest of the code, but the values are now in canvas pixels.
      originalPdfX: originalCanvasX,
      originalPdfY: originalCanvasY,
      originalPdfW: originalCanvasW,
      originalPdfH: originalCanvasH
    };

    textEdits.push(newEdit);

    // Hide original span logically in text layer
    span.style.opacity = '0';
    span.style.pointerEvents = 'none';

    // 2. Draw solid masking rectangle directly onto canvas pixels.
    drawPageCanvasMasks(canvas, pageNum);

    // 3. Render Editable Text Box
    renderTextBoxElement(overlay, newEdit);
    selectTextBox(id);
  }

  function adjustTextWidthScale(box: HTMLDivElement, textContent: HTMLDivElement) {
    // Reset any transform - let text wrap naturally within the box
    textContent.style.transform = 'none';
    textContent.style.width = '100%';
  }

  function renderTextBoxElement(overlay: HTMLDivElement, edit: TextEdit) {
    const box = document.createElement('div');
    box.className = 'absolute border border-transparent p-0 m-0 cursor-text select-text flex items-center page-text-box pointer-events-auto';
    
    box.style.left = `${edit.xPct}%`;
    box.style.top = `${edit.yPct}%`;
    box.style.width = `${edit.wPct}%`;
    box.style.height = `${edit.hPct}%`;
    box.style.minWidth = '60px';
    box.style.minHeight = '24px';
    
    box.style.fontFamily = edit.fontFamily;
    box.style.fontSize = `${edit.fontSize * zoomFactor}px`; 
    box.style.color = edit.color;
    box.style.fontWeight = edit.bold ? 'bold' : 'normal';
    box.style.fontStyle = edit.italic ? 'italic' : 'normal';
    box.style.textDecoration = edit.underline ? 'underline' : 'none';
    box.style.letterSpacing = edit.letterSpacing;
    box.style.lineHeight = edit.lineHeight;
    box.style.textAlign = edit.textAlign;
    if (edit.transform) {
      box.style.transform = edit.transform;
      box.style.transformOrigin = edit.transformOrigin;
    }
    box.dataset.id = edit.id;

    const textContent = document.createElement('div');
    textContent.className = 'outline-none w-full h-full text-content bg-transparent p-0 m-0';
    textContent.contentEditable = 'true';
    textContent.textContent = edit.text;
    
    // Disable browser autocorrect and spelling outlines
    textContent.setAttribute('spellcheck', 'false');
    textContent.setAttribute('autocorrect', 'off');
    textContent.setAttribute('autocomplete', 'off');
    textContent.setAttribute('autocapitalize', 'off');

    box.appendChild(textContent);
    overlay.appendChild(box);

    // Click selects text box
    box.addEventListener('click', (e) => {
      selectTextBox(edit.id);
    });

    // Adjust scale on typing/focus to fit width bounds exactly
    adjustTextWidthScale(box, textContent);
    textContent.addEventListener('input', () => {
      edit.text = textContent.textContent || '';
      adjustTextWidthScale(box, textContent);
      markUnsaved();
    });

    textContent.addEventListener('focus', () => {
      selectTextBox(edit.id);
      adjustTextWidthScale(box, textContent);
    });

    textContent.addEventListener('blur', async () => {
      const trimmedText = textContent.textContent?.trim() || '';
      if (!trimmedText) {
        // Automatically delete the text edit block
        const idx = textEdits.findIndex(evt => evt.id === edit.id);
        if (idx !== -1) {
          textEdits.splice(idx, 1);
        }
        box.remove();
        if (selectedBoxId === edit.id) {
          selectedBoxId = null;
          textFormattingToolbar?.classList.add('hidden');
        }
        markUnsaved();
        // Re-render page to clear canvas mask and restore original text
        await triggerPageReRender(edit.pageNum);
      } else {
        edit.text = textContent.textContent || '';
        adjustTextWidthScale(box, textContent);
        markUnsaved();
      }
    });

    // Adobe Acrobat Keyboard bindings (Enter saves/commits, Escape cancels edits)
    textContent.addEventListener('keydown', (evt) => {
      if (evt.key === 'Enter' && !evt.shiftKey) {
        evt.preventDefault();
        textContent.blur(); // Triggers blur which commits changes
      }
      if (evt.key === 'Escape') {
        evt.preventDefault();
        if (edit.originalText !== undefined) {
          textContent.textContent = edit.originalText;
          edit.text = edit.originalText;
        }
        textContent.blur();
      }
    });
  }

  function selectTextBox(id: string) {
    deselectActiveTextBox();
    selectedBoxId = id;

    const div = document.querySelector(`.page-text-box[data-id="${id}"]`) as HTMLDivElement;
    if (div) {
      div.classList.add('selected');
      
      const txt = div.querySelector('.text-content') as HTMLDivElement;
      if (document.activeElement !== txt) {
        txt.focus();
      }

      textFormattingToolbar?.classList.remove('hidden');

      const edit = textEdits.find(e => e.id === id);
      if (edit) {
        const cleanFam = (edit.originalPdfFontFamily || edit.fontFamily).replace(/[^a-zA-Z0-9]/g, '').toLowerCase();
        let familySelectVal = 'Helvetica';
        if (cleanFam.includes('times') || cleanFam.includes('serif')) familySelectVal = 'Times Roman';
        if (cleanFam.includes('courier') || cleanFam.includes('mono')) familySelectVal = 'Courier';

        propFontFamily.value = familySelectVal;
        tbFontFamily.value = familySelectVal;

        propFontSize.value = Math.round(edit.fontSize).toString();
        tbFontSize.value = Math.round(edit.fontSize).toString();

        const hexColor = cssColorToHex(edit.color);
        propFontColor.value = hexColor;
        tbFontColor.value = hexColor;

        updateFormattingButtonsState(edit);
      }
    }
  }

  function deselectActiveTextBox() {
    if (selectedBoxId) {
      const div = document.querySelector(`.page-text-box[data-id="${selectedBoxId}"]`) as HTMLDivElement;
      if (div) {
        div.classList.remove('selected');
        const txt = div.querySelector('.text-content') as HTMLDivElement;
        txt.blur();
      }
      selectedBoxId = null;
      textFormattingToolbar?.classList.add('hidden');
    }
  }

  // Signature Pad setups
  function setupSignaturePad() {
    if (!signaturePad || !sigCtx) return;

    // Match canvas resolution to display size for proper aspect ratio
    const rect = signaturePad.getBoundingClientRect();
    signaturePad.width = rect.width;
    signaturePad.height = rect.height;
    sigCtx.lineWidth = 3;
    sigCtx.lineCap = 'round';
    sigCtx.strokeStyle = '#000000';

    const getMousePos = (e: MouseEvent | TouchEvent) => {
      const rect = signaturePad.getBoundingClientRect();
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      return {
        x: ((clientX - rect.left) / rect.width) * signaturePad.width,
        y: ((clientY - rect.top) / rect.height) * signaturePad.height
      };
    };

    const startDraw = (e: MouseEvent | TouchEvent) => {
      isDrawingSig = true;
      const pos = getMousePos(e);
      sigCtx.beginPath();
      sigCtx.moveTo(pos.x, pos.y);
      e.preventDefault();
    };

    const draw = (e: MouseEvent | TouchEvent) => {
      if (!isDrawingSig) return;
      const pos = getMousePos(e);
      sigCtx.lineTo(pos.x, pos.y);
      sigCtx.stroke();
      e.preventDefault();
    };

    const stopDraw = () => {
      isDrawingSig = false;
    };

    signaturePad.addEventListener('mousedown', startDraw);
    signaturePad.addEventListener('mousemove', draw);
    signaturePad.addEventListener('mouseup', stopDraw);
    signaturePad.addEventListener('mouseleave', stopDraw);

    signaturePad.addEventListener('touchstart', startDraw, { passive: false });
    signaturePad.addEventListener('touchmove', draw, { passive: false });
    signaturePad.addEventListener('touchend', stopDraw);

    clearSignatureBtn?.addEventListener('click', () => {
      sigCtx.clearRect(0, 0, signaturePad.width, signaturePad.height);
    });

    closeSignatureModal?.addEventListener('click', closeSignatureDialog);

    saveSignatureBtn?.addEventListener('click', () => {
      const dataUrl = signaturePad.toDataURL();
      savedSignatureDataUrl = dataUrl;

      if (signatureClickPosition) {
        const overlay = document.querySelector(`.page-overlay[data-page-num="${signatureClickPosition.pageNum}"]`) as HTMLDivElement;
        if (overlay) {
          placeSignature(overlay, signatureClickPosition.xPct, signatureClickPosition.yPct, dataUrl);
          toggleTool('signature');
        }
      }
      closeSignatureDialog();
    });
  }

  function openSignatureDialog() {
    signatureModal?.classList.remove('hidden');
    if (sigCtx) sigCtx.clearRect(0, 0, signaturePad.width, signaturePad.height);
  }

  function closeSignatureDialog() {
    signatureModal?.classList.add('hidden');
    signatureClickPosition = null;
  }

  function placeSignature(overlay: HTMLDivElement, leftPct: number, topPct: number, dataUrl: string) {
    const box = document.createElement('div');
    box.className = 'absolute border border-transparent hover:border-brand-500 hover:bg-white/40 p-1 rounded cursor-move group page-signature-box pointer-events-auto transition-all shadow-sm';
    box.style.left = `${leftPct}%`;
    box.style.top = `${topPct}%`;
    box.style.transform = 'translate(-50%, -50%)';
    box.style.width = '160px';

    const img = document.createElement('img');
    img.src = dataUrl;
    img.className = 'w-full h-auto pointer-events-none select-none';
    box.appendChild(img);

    const delBtn = document.createElement('button');
    delBtn.className = 'absolute -top-2 -right-2 hidden group-hover:flex items-center justify-center h-5 w-5 bg-red-500 hover:bg-red-600 text-white rounded-full shadow-sm cursor-pointer z-10';
    delBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>';
    delBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      box.remove();
      markUnsaved();
    });
    box.appendChild(delBtn);

    overlay.appendChild(box);
    markUnsaved();

    // Draggable signature
    let isDragging = false;
    let startX = 0;
    let startY = 0;

    const handleMouseMove = (e: MouseEvent) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;

      startX = e.clientX;
      startY = e.clientY;

      const overlayRect = overlay.getBoundingClientRect();

      const newLeftPx = box.offsetLeft + dx;
      const newTopPx = box.offsetTop + dy;

      const newLeftPct = (newLeftPx / overlayRect.width) * 100;
      const newTopPct = (newTopPx / overlayRect.height) * 100;

      box.style.left = `${newLeftPct}%`;
      box.style.top = `${newTopPct}%`;
      markUnsaved();
    };

    const handleMouseUp = () => {
      isDragging = false;
      document.removeEventListener('mousemove', handleMouseMove);
      document.removeEventListener('mouseup', handleMouseUp);
    };

    box.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startY = e.clientY;
      e.preventDefault();
      document.addEventListener('mousemove', handleMouseMove);
      document.addEventListener('mouseup', handleMouseUp);
    });
  }

  const customFontsCache: Record<string, any> = {};

  async function getEmbeddableFont(doc: any, familyName: string, bold: boolean, italic: boolean) {
    const cacheKey = `${familyName}_${bold}_${italic}`;
    if (customFontsCache[cacheKey]) {
      return customFontsCache[cacheKey];
    }

    const GOOGLE_FONTS_TTF_MAP: Record<string, string> = {
      'Arial': 'https://fonts.gstatic.com/s/arimo/v28/P5sMzZBgqg7A9cpx61g.ttf',
      'Arial-Bold': 'https://fonts.gstatic.com/s/arimo/v28/P5sMzZBgqg7A9cpx61g.ttf',
      'Calibri': 'https://fonts.gstatic.com/s/carlito/v14/E21QO5GSDk28fM4R_GNV.ttf',
      'Times New Roman': 'https://fonts.gstatic.com/s/tinos/v20/Gg8zN51QTu7jE4XN8w.ttf',
      'Courier New': 'https://fonts.gstatic.com/s/cousine/v26/d4K7ni8c15_52E4YtA.ttf',
      'Roboto': 'https://fonts.gstatic.com/s/roboto/v30/KFOmCnqEu92Fr1Mu4mxK.ttf',
      'Open Sans': 'https://fonts.gstatic.com/s/opensans/v40/memvYaGs126MiZpBA-UvWbX2vVnXBbObj2OVTS-mu0SC5cK_.ttf',
    };

    let matchKey = '';
    const cleanFamily = familyName.replace(/[^a-zA-Z0-9]/g, '').toLowerCase();

    if (cleanFamily.includes('arial') || cleanFamily.includes('helvetica')) {
      matchKey = 'Arial';
    } else if (cleanFamily.includes('calibri') || cleanFamily.includes('carlito')) {
      matchKey = 'Calibri';
    } else if (cleanFamily.includes('times') || cleanFamily.includes('tinos') || cleanFamily.includes('serif')) {
      matchKey = 'Times New Roman';
    } else if (cleanFamily.includes('courier') || cleanFamily.includes('cousine') || cleanFamily.includes('mono')) {
      matchKey = 'Courier New';
    } else if (cleanFamily.includes('roboto')) {
      matchKey = 'Roboto';
    } else if (cleanFamily.includes('opensans')) {
      matchKey = 'Open Sans';
    }

    if (matchKey && GOOGLE_FONTS_TTF_MAP[matchKey]) {
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 5000);
        const res = await fetch(GOOGLE_FONTS_TTF_MAP[matchKey], { signal: controller.signal });
        clearTimeout(timeoutId);
        
        if (res.ok) {
          const fontBytes = await res.arrayBuffer();
          const customFont = await doc.embedFont(fontBytes);
          customFontsCache[cacheKey] = customFont;
          return customFont;
        }
      } catch (e) {
        console.warn("Failed to load web font for family:", familyName, e);
      }
    }

    const fontName = getPdfStandardFontName(familyName, bold, italic);
    
    const banner = document.getElementById('substitution-warning-banner');
    if (banner) banner.classList.remove('hidden');

    const embeddedFont = await doc.embedFont(fontName);
    customFontsCache[cacheKey] = embeddedFont;
    return embeddedFont;
  }

  function getPdfStandardFontName(family: string, bold: boolean, italic: boolean) {
    // @ts-ignore
    const { StandardFonts } = window.PDFLib;
    const cleanFamily = family.replace(/[^a-zA-Z0-9]/g, '').toLowerCase();
    
    if (cleanFamily.includes('times') || cleanFamily.includes('serif') || cleanFamily.includes('tinos')) {
      if (bold && italic) return StandardFonts.TimesRomanBoldItalic;
      if (bold) return StandardFonts.TimesRomanBold;
      if (italic) return StandardFonts.TimesRomanItalic;
      return StandardFonts.TimesRoman;
    } else if (cleanFamily.includes('courier') || cleanFamily.includes('mono') || cleanFamily.includes('cousine')) {
      if (bold && italic) return StandardFonts.CourierBoldOblique;
      if (bold) return StandardFonts.CourierBold;
      if (italic) return StandardFonts.CourierOblique;
      return StandardFonts.Courier;
    } else {
      if (bold && italic) return StandardFonts.HelveticaBoldOblique;
      if (bold) return StandardFonts.HelveticaBold;
      if (italic) return StandardFonts.HelveticaOblique;
      return StandardFonts.Helvetica;
    }
  }

  async function downloadEditedPdf() {
    if (!pdfBytes) return;
    deselectActiveTextBox();

    downloadBtn.disabled = true;
    downloadBtn.textContent = 'Saving...';

    try {
      // @ts-ignore
      const { PDFDocument, rgb } = window.PDFLib;
      
      const doc = await PDFDocument.load(pdfBytes);
      const pages = doc.getPages();

      // Loop through pages and apply edits/masks
      for (const p of pagesRendered) {
        const pageNum = parseInt(p.overlay.dataset.pageNum || '1');
        const page = pages[pageNum - 1];
        const overlay = p.overlay;

        const pdfWidth = page.getWidth();
        const pdfHeight = page.getHeight();

        const overlayRect = overlay.getBoundingClientRect();
        const scaleX = pdfWidth / overlayRect.width;
        const scaleY = pdfHeight / overlayRect.height;

        const pageEdits = textEdits.filter(e => e.pageNum === pageNum);
        for (const edit of pageEdits) {
          const text = edit.text.trim();
          
          // Parse RGB masking color
          let maskR = 1, maskG = 1, maskB = 1; // Default white
          const hex = edit.backgroundColor;
          if (hex.startsWith('#') && hex.length === 7) {
            maskR = parseInt(hex.slice(1, 3), 16) / 255;
            maskG = parseInt(hex.slice(3, 5), 16) / 255;
            maskB = parseInt(hex.slice(5, 7), 16) / 255;
          }

          // 1. Draw solid masking rectangle in final PDF using exact sampled background color.
          //    Note: originalPdfX/Y/W/H are stored in CANVAS PIXEL SPACE (top-left origin).
          //    Convert to PDF space (bottom-left origin) by MULTIPLYING by scale (not dividing).
          if (edit.originalText && edit.originalPdfX !== undefined && edit.originalPdfY !== undefined) {
            // Expand mask by 1px in each direction (in PDF units) for full anti-aliased coverage.
            const maskPdfW = (edit.originalPdfW! * scaleX) + 2;
            const maskPdfH = (edit.originalPdfH! * scaleY) + 2;
            const maskPdfX = (edit.originalPdfX * scaleX) - 1;
            const maskPdfY = pdfHeight - (edit.originalPdfY * scaleY) - (edit.originalPdfH * scaleY) - 1;
            page.drawRectangle({
              x: maskPdfX,
              y: maskPdfY,
              width: maskPdfW,
              height: maskPdfH,
              color: rgb(maskR, maskG, maskB)
            });
          }

if (!text) continue;

          // 2. Draw edited/added text
          const boxLeftPx = (edit.xPct / 100) * overlayRect.width;
          const boxTopPx = (edit.yPct / 100) * overlayRect.height;
          
          let pdfX = boxLeftPx * scaleX;
          const pdfY = pdfHeight - (boxTopPx * scaleY) - (edit.hPct / 100 * overlayRect.height * scaleY);
          
          let pdfFontSize = edit.fontSize * scaleY * zoomFactor;

          const font = await getEmbeddableFont(doc, edit.originalPdfFontFamily || edit.fontFamily, edit.bold, edit.italic);

          // originalPdfX/W are in CANVAS PIXEL SPACE. Convert to PDF space by * scaleX.
          const boxWidth = edit.originalPdfW !== undefined
            ? (edit.originalPdfW * scaleX)
            : (edit.wPct / 100 * overlayRect.width * scaleX);
          const currentW = font.widthOfTextAtSize(text, pdfFontSize);

          // Horizontal width scaling to keep text strictly within bounding footprint
          if (currentW > boxWidth) {
            pdfFontSize = pdfFontSize * (boxWidth / currentW);
          }

          // Alignment adjustments
          const boxLeft = edit.originalPdfX !== undefined ? (edit.originalPdfX * scaleX) : pdfX;
          
          if (edit.textAlign === 'center') {
            const boxCenter = boxLeft + boxWidth / 2;
            pdfX = boxCenter - (font.widthOfTextAtSize(text, pdfFontSize) / 2);
          } else if (edit.textAlign === 'right') {
            const boxRight = boxLeft + boxWidth;
            pdfX = boxRight - font.widthOfTextAtSize(text, pdfFontSize);
          }

          // Parse text fill color
          const { r, g, b } = cssColorToRgb(edit.color);

          const letterSpacingPx = parseFloat(edit.letterSpacing) || 0;
          const pdfCharSpacing = letterSpacingPx * scaleY;

          // Multi-line spacing
          const lines = text.split('\n');
          const boxHeight = edit.hPct / 100 * overlayRect.height * scaleY;
          
          // Parse line-height: could be "1.5" (ratio), "24px" (pixel), or "normal"
          let lineSpacing: number;
          if (edit.lineHeight && edit.lineHeight !== 'normal') {
            const lhVal = parseFloat(edit.lineHeight);
            if (edit.lineHeight.endsWith('px')) {
              // Pixel value — convert to PDF points via scaleY
              lineSpacing = lhVal * scaleY;
            } else {
              // Unitless ratio — multiply by font size
              lineSpacing = pdfFontSize * lhVal;
            }
          } else {
            lineSpacing = pdfFontSize * 1.25;
          }
          
          // Position text using font ascent for exact baseline alignment.
          // Use the original font's ascent when available (from PDF.js text content metadata),
          // otherwise fall back to a standard approximation (0.7 of font size).
          const ascentRatio = edit.originalFontAscent !== undefined ? edit.originalFontAscent : 0.7;
          const ascent = pdfFontSize * ascentRatio;
          let currentY = pdfY + boxHeight - ascent;

          for (const line of lines) {
            page.drawText(line, {
              x: pdfX,
              y: currentY,
              size: pdfFontSize,
              font: font,
              color: rgb(r, g, b),
              characterSpacing: pdfCharSpacing
            });

            // Draw Underline
            if (edit.underline) {
              const textWidth = font.widthOfTextAtSize(line, pdfFontSize);
              page.drawLine({
                start: { x: pdfX, y: currentY - pdfFontSize * 0.1 },
                end: { x: pdfX + textWidth, y: currentY - pdfFontSize * 0.1 },
                thickness: 1,
                color: rgb(r, g, b)
              });
            }
            currentY -= lineSpacing;
          }
        }

        // Apply Signatures
        const signatureElements = overlay.querySelectorAll('.page-signature-box');
        for (const element of signatureElements) {
          const el = element as HTMLDivElement;
          const imgEl = el.querySelector('img') as HTMLImageElement;
          if (!imgEl || !imgEl.src) continue;

          const elRect = el.getBoundingClientRect();
          const leftPx = elRect.left - overlayRect.left;
          const topPx = elRect.top - overlayRect.top;

          const pdfX = leftPx * scaleX;
          const pdfY = pdfHeight - (topPx * scaleY) - (elRect.height * scaleY);
          const pdfW = elRect.width * scaleX;
          const pdfH = elRect.height * scaleY;

          const sigImg = await doc.embedPng(imgEl.src);
          page.drawImage(sigImg, {
            x: pdfX,
            y: pdfY,
            width: pdfW,
            height: pdfH
          });
        }

        // Apply Highlights
        const highlightElements = overlay.querySelectorAll('.page-highlight-box');
        for (const element of highlightElements) {
          const el = element as HTMLDivElement;
          const elRect = el.getBoundingClientRect();
          const leftPx = elRect.left - overlayRect.left;
          const topPx = elRect.top - overlayRect.top;

          const pdfX = leftPx * scaleX;
          const pdfY = pdfHeight - (topPx * scaleY) - (elRect.height * scaleY);
          const pdfW = elRect.width * scaleX;
          const pdfH = elRect.height * scaleY;

          page.drawRectangle({
            x: pdfX,
            y: pdfY,
            width: pdfW,
            height: pdfH,
            color: rgb(1, 1, 0),
            opacity: 0.35
          });
        }
      }

      const finalPdfBytes = await doc.save();
      
      const fileName = document.getElementById('editor-file-name')?.textContent || 'document.pdf';
      const blob = new Blob([finalPdfBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = fileName.endsWith('.pdf') ? fileName : `${fileName}.pdf`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
      
      markSaved();
      await clearStoredPdf();
    } catch (err) {
      console.error('Error saving PDF:', err);
      alert('Failed to save and compile PDF document. Please try again.');
    } finally {
      downloadBtn.disabled = false;
      downloadBtn.textContent = 'Download';
    }
  }
</script>