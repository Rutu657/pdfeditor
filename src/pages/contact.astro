---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us | PDF Editor">
  <div class="py-24 bg-white flex-1">
    <div class="container mx-auto px-4 max-w-xl text-center">
      <h1 class="text-4xl font-bold tracking-tight mb-4 text-slate-900">Contact Us</h1>
      <p class="text-slate-600 mb-12">Have questions or need support? We're here to help.</p>
      
      <form id="contact-form" class="space-y-6 text-left">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Name</label>
          <input type="text" id="contact-name" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-brand-500 focus:border-brand-500" required>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Email</label>
          <input type="email" id="contact-email" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-brand-500 focus:border-brand-500" required>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Message</label>
          <textarea rows="4" id="contact-message" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-brand-500 focus:border-brand-500" required></textarea>
        </div>
        <div id="contact-success" class="hidden bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md text-sm">Thank you! Your message has been received.</div>
        <button type="submit" class="w-full bg-brand-600 text-white font-medium py-2.5 rounded-md hover:bg-brand-700 transition-colors">Send Message</button>
      </form>
      <script>
        document.getElementById('contact-form')?.addEventListener('submit', (e) => {
          e.preventDefault();
          const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
          const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
          const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();
          if (!name || !email || !message) return;
          document.getElementById('contact-success')?.classList.remove('hidden');
          (document.getElementById('contact-form') as HTMLFormElement).reset();
        });
      </script>
    </div>
  </div>
</Layout>